{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/theme/*": [
        "./src/theme/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/models/*": [
        "./src/models/*"
      ],
      "@/database/*": [
        "./src/database/*"
      ],
      "@/utils/*": [
        "./src/utils/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
